APP_ENV=dev
APP_NAME=Secure AI Insights Assistant

JWT_SECRET=change-me
JWT_ALG=HS256
JWT_AUDIENCE=secure-ai-insights
JWT_ISSUER=secure-ai-insights-api
JWT_NBF_SKEW_SECONDS=0
JWT_TTL_SECONDS=3600

LOG_LEVEL=INFO

# Folder under backend/ containing demo CSVs and pdfs/ (in-memory only; no DATABASE_URL).
DEMO_DATA_DIR=demo_data

# sentence_transformers | openai | local_hash (MiniLM runs locally; no Groq embeddings)
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

LLM_PROVIDER=groq

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-70b-versatile

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

FRONTEND_ORIGIN=http://localhost:3000

# SQLite login; first-time seed creates admin if missing.
AUTH_DB_PATH=data/auth.db
ADMIN_EMAIL=adminlocalhost@gmail.com
ADMIN_PASSWORD=admin
